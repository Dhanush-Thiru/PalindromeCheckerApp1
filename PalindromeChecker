import java.util.Scanner;
import java.util.Stack;

public class PalindromeChecker {

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        System.out.println("--- UC5: Stack-Based Palindrome Checker ---");
        System.out.print("Enter a string to check: ");
        String input = scanner.nextLine();

        if (isPalindrome(input)) {
            System.out.println("Result: '" + input + "' is a palindrome.");
        } else {
            System.out.println("Result: '" + input + "' is NOT a palindrome.");
        }

        scanner.close();
    }

    /**
     * Validates if a string is a palindrome using a Stack.
     */
    public static boolean isPalindrome(String input) {
        // Remove non-alphanumeric characters and convert to lowercase for accuracy
        String cleanInput = input.replaceAll("[^a-zA-Z0-9]", "").toLowerCase();
        
        Stack<Character> stack = new Stack<>();

        // Step 1: Push all characters onto the stack
        for (int i = 0; i < cleanInput.length(); i++) {
            stack.push(cleanInput.charAt(i));
        }

        // Step 2: Pop characters and compare with the original string
        // Since the stack is LIFO, popping gives characters in reverse order
        for (int i = 0; i < cleanInput.length(); i++) {
            char reverseChar = stack.pop();
            if (cleanInput.charAt(i) != reverseChar) {
                return false; // Mismatch found
            }
        }

        return true; // All characters matched
    }
}
